<% content_for :title, "New chat" %>

<div class="min-h-screen bg-[var(--cf-bg)]">
  <div class="px-7 pt-8">
    <h1 class="cf-headline text-[clamp(72px,13vw,120px)] mb-10">NEW<br>CHAT</h1>

    <%= render "form", chat: @chat %>
  </div>
  <%= render "form", chat: @chat, seed_prompt: @seed_prompt %>

  <%= link_to "Back to chats", chats_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
</div>
