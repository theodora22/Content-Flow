<% content_for :title, "Chat" %>

<%# Turbo Drive caches the current page before navigating away. If the user
    returns, it would show the stale snapshot as a "preview" while the fresh
    page loads. During that brief window a second turbo-cable-stream-source
    connects and then immediately disconnects, dropping the real subscription.
    no-preview disables the preview entirely: Turbo Drive still caches for the
    back button but never shows it as a live preview. %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-preview">
<% end %>

<%= turbo_stream_from "chat_#{@chat.id}" %>

<div class="min-h-screen">
  <div class="px-7 pt-2 pb-36">

    <% platform_post_purposes = %w[generate_linkedin_post generate_twitter_post generate_instagram_post] %>
    <% if platform_post_purposes.include?(@chat.purpose) && @chat.chattable.is_a?(Script) %>
      <%= render "shared/back_link", path: script_path(@chat.chattable), label: "go back to script" %>
    <% else %>
      <%= render "shared/back_link", path: chats_path, label: "go back to chats" %>
    <% end %>

    <% if notice.present? %>
      <p class="cf-meta py-2 px-4 mb-4 border-l-4 border-[var(--cf-orange)] inline-block" id="notice">
        <%= notice %>
      </p>
    <% end %>

    <%# <%== outputs HTML without escaping — same as raw(). Safe here because
 20 +        the string comes from a hardcoded hash, never from user input. %>

    <%
      headline_html = {
        "generate_idea"          => "GENERATE<br>AN IDEA",
        "generate_script"        => "GENERATE<br>A SCRIPT",
        "generate_linkedin_post" => "GENERATE<br>LINKEDIN POST",
        "generate_twitter_post"   => "GENERATE<br>TWITTER POST",
        "generate_instagram_post" => "GENERATE<br>INSTAGRAM POST"
      }[@chat.purpose] || "CHAT"
    %>
    <h1 class="cf-headline text-[clamp(72px,13vw,120px)] mb-10" style="margin-top: 10px;"><%== headline_html %></h1>

    <div id="messages" class="space-y-4 mb-8" data-controller="chat-scroll">
      <% @chat.messages.where.not(id: nil).each do |message| %>
        <%= render message %>
      <% end %>
      <% if @chat.messages.where(role: %w[user assistant]).order(:id).last&.role.to_s == "user" %>
        <%= render "messages/thinking" %>
      <% end %>
    </div>

    <%= render "messages/form", chat: @chat, message: @message %>

    <%= render "generation_action", chat: @chat %>

  </div>
</div>
