<%= form_with(model: chat, url: chats_path, class: "contents") do |form| %>
  <%= form.hidden_field :purpose, value: @purpose %>
  <%= form.hidden_field :chattable_type, value: chat.chattable_type %>
  <%= form.hidden_field :chattable_id, value: chat.chattable_id %>

  <% if chat.errors.any? %>
    <div class="cf-errors mb-6">
      <ul>
        <% chat.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-6 hidden">
    <%= form.label :model, "model", class: "cf-form-label" %>
    <%= form.select :model,
          options_for_select(
            @chat_models.map { |m| [m.label, m.id] }.unshift([default_model_display_name, nil]),
            @selected_model
          ),
          {},
          class: "cf-select mt-2" %>
  </div>

  <% seeded = local_assigns[:seed_prompt].present? %>
  <div class="fixed bottom-0 left-0 right-0 px-7 pb-8 pt-3 z-10">
    <div class="flex items-end gap-6">
      <%= form.text_area :prompt, rows: 1,
            placeholder: "chat with CeCe...",
            autofocus: true,
            value: local_assigns[:seed_prompt],
            class: "flex-1 bg-transparent border-none outline-none font-normal py-3 placeholder-[var(--cf-fg-muted)] resize-none overflow-hidden",
            style: "field-sizing: content; font-size: #{seeded ? 'var(--cf-text-sm)' : '52px'}; line-height: #{seeded ? '1.4' : '1'}; letter-spacing: var(--cf-tracking); caret-color: var(--cf-orange);" %>
      <%= form.button class: "shrink-0 pb-3 cursor-pointer hover:opacity-70 transition-opacity duration-150" do %>
        <%= image_tag "arrow.svg", style: "width: 28px; height: 28px; pointer-events: none;", alt: "send" %>
      <% end %>
    </div>
    <div class="h-[3px] bg-[var(--cf-orange)] rounded-full"></div>
  </div>
<% end %>
