<%= form_with(model: chat, url: chats_path, class: "contents") do |form| %>
  <%# Carries the chat's purpose + owner through to #create. All three render
      empty for a plain free-form chat (no purpose/chattable), so that flow is
      unchanged. The chattable fields are seeded by #new from the generate
      redirect's params so the created chat keeps its owner (and its context). %>
  <%= form.hidden_field :purpose, value: @purpose %>
  <%= form.hidden_field :chattable_type, value: chat.chattable_type %>
  <%= form.hidden_field :chattable_id, value: chat.chattable_id %>

  <% if chat.errors.any? %>
    <div class="cf-errors mb-6">
      <ul>
        <% chat.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-6">
    <%= form.label :model, "model", class: "cf-form-label" %>
    <%= form.select :model,
          options_for_select(
            @chat_models.map { |m| [m.label, m.id] }.unshift([default_model_display_name, nil]),
            @selected_model
          ),
          {},
          class: "cf-select mt-2" %>
  </div>

  <div class="mb-8">
    <%= form.label :prompt, "prompt", class: "cf-form-label" %>
    <%= form.text_area :prompt, rows: 4,
          placeholder: "what would you like to discuss?",
          autofocus: true,
          class: "cf-textarea mt-2" %>
  <div class="my-5">
    <%= form.label :prompt, "Prompt" %>
    <%= form.text_area :prompt, rows: 4,
        placeholder: "What would you like to discuss?",
        autofocus: true,
        value: local_assigns[:seed_prompt],
        class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": chat.errors[:prompt].none?, "border-red-400 focus:outline-red-600": chat.errors[:prompt].any?}] %>
  </div>

  <%= form.button "start chat", class: "cf-btn-primary bg-[var(--cf-orange)] hover:bg-[var(--cf-orange-press)] active:translate-y-px text-white rounded-full py-4 px-10" %>
<% end %>
