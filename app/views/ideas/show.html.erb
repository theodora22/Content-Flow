<% content_for :title, @idea.title %>

<div class="flex flex-col" style="height: calc(100vh - 64px);" data-controller="idea-edit">
  <div class="px-7 pt-2 flex flex-col flex-1 overflow-hidden">
    <%= link_to ideas_path, class: "cf-meta inline-flex items-center gap-2 hover:text-[var(--cf-orange)] transition-colors duration-150", style: "position: relative; z-index: 20; cursor: pointer;" do %>
      <%= image_tag "arrow.svg", style: "width: 20px; height: 20px; transform: rotate(180deg); pointer-events: none;", alt: "" %>
      <span style="pointer-events: none;">go back to ideas</span>
    <% end %>
    <div data-idea-edit-target="header" class="flex justify-between items-start mb-10 relative z-10">
      <h1 class="cf-headline text-[clamp(72px,13vw,120px)]" style="margin-top: 10px;" data-idea-edit-target="showTitle"><%= @idea.title.upcase %></h1>
      <div class="shrink-0 pt-2">
        <button type="button" data-idea-edit-target="pen" data-action="idea-edit#toggle" class="edit-pen-btn flex flex-col items-center">
          <div data-idea-edit-target="penIcon" class="w-14 h-14">
            <svg class="pen-icon-svg w-full h-full" preserveAspectRatio="none" overflow="visible" style="display: block;" viewBox="0 0 808.169 808.169" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M404.085 261.319L546.851 404.085M47.1694 761V582.542L582.542 47.1694L761 225.627L225.627 761H47.1694Z" stroke="var(--stroke-0, black)" stroke-width="50" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div data-idea-edit-target="penLine" class="w-14 mt-1 h-0.5 overflow-hidden transition-all duration-500 ease-in-out">
            <div class="pen-line-inner w-14 h-0.5">
              <svg class="w-full h-full" preserveAspectRatio="none" overflow="visible" style="display: block;" viewBox="0 0 761 31.4463" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="15.7231" y1="15.7231" x2="745.277" y2="15.7231" stroke="var(--stroke-0, black)" stroke-width="31.4463" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
          <span data-idea-edit-target="editLabel" class="edit-label cf-meta mt-1 w-14 text-center tracking-[0.3em]">edit</span>
        </button>
      </div>
    </div>

    <%# ---- Show content ---- %>
    <div class="overflow-hidden" style="margin-top: 15px;">
    <div data-idea-edit-target="show">
      <p class="cf-h2 font-normal mb-4" data-idea-edit-target="showPart showTopic"><%= @idea.topic %></p>
      <p class="cf-body mb-10 max-w-2xl" data-idea-edit-target="showPart showDescription"><%= @idea.description %></p>

      <div data-idea-edit-target="showPart" class="overflow-x-auto">
        <table class="w-full border-collapse min-w-[500px]">
          <thead>
            <tr class="text-left">
              <th class="pt-12 pb-3 cf-h2 font-normal">script title</th>
              <th class="pt-12 pb-3 cf-h2 font-normal">style</th>
              <th class="pt-12 pb-3 cf-h2 font-normal">created</th>
              <th class="pt-12 pb-3 cf-h2 font-normal text-right">
                <%= link_to new_idea_script_path(@idea), class: "inline-flex items-center gap-2 hover:text-[var(--cf-orange)] transition-colors duration-150" do %>
                  <%= image_tag "big_plus.svg", class: "w-6 h-6 translate-y-1", alt: "New script" %>
                  <span>write a script</span>
                <% end %>
              </th>
            </tr>
          </thead>
          <tr><td colspan="4"><div class="cf-rule"></div></td></tr>
          <tbody>
            <% if @idea.scripts.any? %>
              <% @idea.scripts.each do |script| %>
                <tr class="cf-row cursor-pointer" data-controller="row-link" data-row-link-url-value="<%= script_path(script) %>" data-action="click->row-link#visit">
                  <td class="py-[18px] cf-label font-normal"><%= script.title.presence || "untitled script" %></td>
                  <td class="py-[18px] cf-label font-normal"><%= script.style %></td>
                  <td class="py-[18px] cf-label font-normal"><%= script.created_at.strftime("%b %d, %Y") %></td>
                  <td class="py-[18px] pr-px cf-label font-normal text-right whitespace-nowrap">
                    <%= link_to "delete", script_path(script),
                          data: { turbo_method: :delete, turbo_confirm: "Delete this script?" },
                          class: "text-[var(--cf-orange)] hover:text-[var(--cf-orange-press)] transition-colors duration-150" %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="4" class="py-10 text-center cf-meta">No scripts yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    </div>

    <%# ---- Edit form (hidden until pen click) ---- %>
    <div data-idea-edit-target="form" class="hidden opacity-0 flex flex-col justify-end flex-1" style="padding-bottom: 28px;">
      <div class="flex items-end justify-between">
        <div class="max-w-lg w-full">
          <%= form_with model: @idea, class: "flex flex-col gap-4" do |f| %>
            <div class="group relative pb-2" data-idea-edit-target="field">
              <%= f.label :title, "title", class: "cf-h2 font-normal" %>
              <%= f.text_field :title,
                readonly: true,
                class: "cf-input cf-input-transparent border-0 rounded-none px-0 outline-none cursor-default",
                placeholder: "your idea title...",
                data: { idea_edit_target: "input" } %>
              <span data-idea-edit-target="line" class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-700 ease-in-out"></span>
            </div>

            <div class="group relative pb-2" data-idea-edit-target="field">
              <%= f.label :topic, "topic", class: "cf-h2 font-normal" %>
              <%= f.text_field :topic,
                readonly: true,
                class: "cf-input cf-input-transparent border-0 rounded-none px-0 outline-none cursor-default",
                placeholder: "e.g. AI & productivity, fitness...",
                data: { idea_edit_target: "input" } %>
              <span data-idea-edit-target="line" class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-700 ease-in-out"></span>
            </div>

            <div class="group relative pb-2" data-idea-edit-target="field">
              <%= f.label :description, "description", class: "cf-h2 font-normal" %>
              <%= f.text_area :description,
                readonly: true,
                rows: 1,
                class: "cf-input cf-input-transparent border-0 rounded-none px-0 outline-none cursor-default h-auto py-3 resize-none overflow-hidden",
                placeholder: "what's this idea about...",
                style: "field-sizing: content; min-height: 46px;",
                data: { idea_edit_target: "input" } %>
              <span data-idea-edit-target="line" class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-700 ease-in-out"></span>
            </div>
          <% end %>
        </div>
        <div class="flex justify-end mt-6">
          <button type="button" data-idea-edit-target="submit" data-action="idea-edit#submit" class="opacity-0 pointer-events-none rounded-[10px] border-2 border-[var(--cf-ink)] bg-transparent text-[var(--cf-ink)] px-8 py-3.5 cf-action font-normal cursor-pointer transition-all duration-300 ease-in-out hover:bg-[var(--cf-accent)] hover:border-[var(--cf-accent)] hover:text-[var(--cf-cream)]">update</button>
        </div>
      </div>
    </div>
  </div>
</div>
