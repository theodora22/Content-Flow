<% content_for :title, "Ideas" %>

<div class="min-h-screen">
  <div class="px-7 pt-8">
    <div class="flex justify-between items-end gap-4">
      <h1 class="cf-headline text-[clamp(72px,13vw,120px)]">
        HERE ARE<br>YOUR <span class="relative inline-block"><span>IDEAS</span><%= image_tag "wavy_underline.svg", class: "absolute left-0 w-full pointer-events-none", style: "bottom: -0.35em; height: 0.3em; transform: rotate(-1deg);", alt: "" %></span>
      </h1>
      <style>
        .liquid-fill {
          clip-path: inset(0 0 100% 0);
          transition: clip-path 0.5s ease-in-out;
        }
        .liquid-btn:hover .liquid-fill {
          clip-path: inset(0 0 0 0);
        }
      </style>
      <%= link_to new_idea_path, class: "shrink-0 flex items-end group liquid-btn" do %>
        <svg viewBox="0 0 151 151" class="w-16 h-16 md:w-28 md:h-28 z-10 relative" xmlns="http://www.w3.org/2000/svg">
           <!-- Base black strokes -->
           <g>
             <path d="M61.06 61.0601H18.46C10.6176 61.0601 4.26001 67.4176 4.26001 75.2601C4.26001 83.1025 10.6176 89.4601 18.46 89.4601H61.06" stroke="black" stroke-width="8.52" stroke-linecap="round" fill="none" />
             <path d="M89.46 61.0601H132.06C139.902 61.0601 146.26 67.4176 146.26 75.2601C146.26 83.1025 139.902 89.4601 132.06 89.4601H89.46" stroke="black" stroke-width="8.52" stroke-linecap="round" fill="none" />
             <path d="M89.46 61.0601L89.46 18.4601C89.46 10.6176 83.1025 4.26006 75.26 4.26006C67.4176 4.26006 61.06 10.6176 61.06 18.46L61.06 61.0601" stroke="black" stroke-width="8.52" stroke-linecap="round" fill="none" />
             <path d="M61.06 89.46L61.06 132.06C61.06 139.902 67.4176 146.26 75.26 146.26C83.1025 146.26 89.46 139.902 89.46 132.06L89.46 89.46" stroke="black" stroke-width="8.52" stroke-linecap="round" fill="none" />
           </g>

           <!-- Animated orange strokes -->
           <g class="liquid-fill">
             <!-- Orange strokes -->
             <path d="M61.06 61.0601H18.46C10.6176 61.0601 4.26001 67.4176 4.26001 75.2601C4.26001 83.1025 10.6176 89.4601 18.46 89.4601H61.06" style="stroke: var(--cf-orange);" stroke-width="8.52" stroke-linecap="round" fill="none" />
             <path d="M89.46 61.0601H132.06C139.902 61.0601 146.26 67.4176 146.26 75.2601C146.26 83.1025 139.902 89.4601 132.06 89.4601H89.46" style="stroke: var(--cf-orange);" stroke-width="8.52" stroke-linecap="round" fill="none" />
             <path d="M89.46 61.0601L89.46 18.4601C89.46 10.6176 83.1025 4.26006 75.26 4.26006C67.4176 4.26006 61.06 10.6176 61.06 18.46L61.06 61.0601" style="stroke: var(--cf-orange);" stroke-width="8.52" stroke-linecap="round" fill="none" />
             <path d="M61.06 89.46L61.06 132.06C61.06 139.902 67.4176 146.26 75.26 146.26C83.1025 146.26 89.46 139.902 89.46 132.06L89.46 89.46" style="stroke: var(--cf-orange);" stroke-width="8.52" stroke-linecap="round" fill="none" />
           </g>
        </svg>
        <span class="cf-action -ml-10 font-normal relative z-30">
          <span class="text-transparent">new idea</span>
          <span class="absolute left-0 top-0 text-[var(--cf-ink)] pointer-events-none" aria-hidden="true">new idea</span>
          <span class="absolute left-0 top-0 text-[var(--cf-orange)] liquid-fill pointer-events-none" aria-hidden="true">new idea</span>
        </span>
      <% end %>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full border-collapse min-w-[500px]">
        <thead>
          <tr class="text-left">
            <th class="pt-12 pb-3 cf-h2 font-normal">title</th>
            <th class="pt-12 pb-3 cf-h2 font-normal">subject</th>
            <th class="pt-12 pb-3 cf-h2 font-normal">created</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <tr><td colspan="4"><div class="cf-rule"></div></td></tr>
          <% if @ideas.any? %>
            <% @ideas.each do |idea| %>
              <tr class="cf-row cursor-pointer" data-controller="row-link" data-row-link-url-value="<%= idea_path(idea) %>" data-action="click->row-link#visit">
                <td class="py-[18px] cf-label font-normal"><%= idea.title %></td>
                <td class="py-[18px] cf-label font-normal"><%= idea.topic %></td>
                <td class="py-[18px] cf-label font-normal"><%= idea.created_at.strftime("%b %d, %Y") %></td>
                <td class="py-[18px] pr-px cf-label font-normal text-right whitespace-nowrap">
                  <%= link_to "edit", edit_idea_path(idea), class: "hover:text-[var(--cf-orange)] transition-colors duration-150" %> /
                  <%= link_to "delete", idea, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-[var(--cf-orange)] hover:text-[var(--cf-orange-press)] transition-colors duration-150" %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="4" class="py-10 text-center cf-meta">No ideas yet. Click + to create your first one.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
