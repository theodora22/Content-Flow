<% assistant ||= local_assigns[:message] %>
<div id="message_<%= assistant.id %>" class="bg-[var(--cf-white)] border-l-4 border-[var(--cf-orange)] rounded-r-[var(--cf-radius)] px-5 py-4">
  <div class="flex justify-between items-baseline gap-4 mb-2">
    <span class="cf-meta text-[var(--cf-orange)]">ai</span>
    <span class="cf-meta"><%= assistant.created_at&.strftime("%I:%M %p") %></span>
  </div>
  <div id="message_<%= assistant.id %>_content" class="cf-body whitespace-pre-wrap"><%= assistant.content %></div>
</div>
