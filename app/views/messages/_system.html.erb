<% system ||= local_assigns[:message] %>
<div id="message_<%= system.id %>">
  <details class="group">
    <summary class="cf-meta text-[var(--cf-gray)] cursor-pointer list-none inline-flex items-center gap-2 hover:text-[var(--cf-orange)] transition-colors duration-150 select-none">
      <%= image_tag "arrow.svg", style: "width: 12px; height: 12px;", class: "transition-transform duration-200 group-open:rotate-90", alt: "" %>
      system prompt
    </summary>
    <div class="cf-body cf-prose mt-3 text-[var(--cf-gray)] whitespace-pre-wrap text-sm"><%= system.content %></div>
  </details>
</div>
