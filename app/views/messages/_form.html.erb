<%= form_with(model: message, url: [@chat, message], id: "new_message", class: "contents") do |form| %>
  <div class="fixed bottom-0 left-0 right-0 px-7 pb-8 pt-3 z-10" data-controller="scroll-hide">
    <% if message.errors.any? %>
      <div class="cf-errors mb-2">
        <ul>
          <% message.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="flex items-end gap-6">
      <%= form.text_area :content,
            rows: 1,
            placeholder: "refine with CeCe...",
            autofocus: true,
            class: "flex-1 bg-transparent border-none outline-none font-normal py-3 placeholder-[var(--cf-fg-muted)] resize-none overflow-hidden",
            style: "field-sizing: content; font-size: 52px; line-height: 1; letter-spacing: -0.04em; caret-color: var(--cf-orange);" %>
      <%= form.button class: "shrink-0 pb-3 cursor-pointer hover:opacity-70 transition-opacity duration-150" do %>
        <%= image_tag "arrow.svg", style: "width: 28px; height: 28px; pointer-events: none;", alt: "send" %>
      <% end %>
    </div>
    <div class="h-[3px] bg-[var(--cf-orange)] rounded-full"></div>
  </div>
<% end %>
