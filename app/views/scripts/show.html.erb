                <path d="M75.0002 100C61.1927 100 49.9999 88.8072 49.9999 75.0002C49.9999 61.1927 61.1927 49.9999 75.0002 49.9999C88.8072 49.9999 100 61.1927 100 75.0002C100 88.8072 88.8072 100 75.0002 100ZM75.0002 36.4865C53.7294 36.4865 36.4865 53.7294 36.4865 75.0002C36.4865 96.2705 53.7294 113.513 75.0002 113.513C96.2705 113.513 113.513 96.2705 113.513 75.0002C113.513 53.7294 96.2705 36.4865 75.0002 36.4865V36.4865ZM124.035 34.9648C124.035 39.9356 120.006 43.9647 115.035 43.9647C110.065 43.9647 106.035 39.9356 106.035 34.9648C106.035 29.9943 110.065 25.9646 115.035 25.9646C120.006 25.9646 124.035 29.9943 124.035 34.9648" fill="var(--fill-0, #100F0D)"/>
              </svg>
            <% end %>
          </div>
        </div>
        <div class="cf-rule"></div>

        <% existing = [
             @script.linkedin_post && { post: @script.linkedin_post, icon: "linkedin.svg", label: "linkedin", path: script_linkedin_post_path(@script) },
             @script.twitter_post  && { post: @script.twitter_post,  icon: "twitter.svg",  label: "twitter",  path: script_twitter_post_path(@script) },
             @script.instagram_post && { post: @script.instagram_post, icon: "instagram.svg", label: "instagram", path: script_instagram_post_path(@script) }
           ].compact %>
        <% if existing.any? %>
          <div class="flex flex-col">
            <% existing.each do |entry| %>
              <%= link_to entry[:path], class: "cf-row inline-flex items-center gap-3 py-[18px] cf-label font-normal hover:text-[var(--cf-orange)] transition-colors duration-150" do %>
                <%= image_tag entry[:icon], class: "w-5 h-5 shrink-0", alt: entry[:label] %>
                <span><%= entry[:post].title %></span>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
    </div>

    <%# ---- Edit form (hidden until pen click) ---- %>
    <div data-script-edit-target="form" class="hidden opacity-0 flex flex-col justify-end" style="min-height: calc(100vh - 180px);">
      <div class="flex items-end justify-between" style="padding-bottom: 90px;">
        <div class="max-w-lg">
          <%= form_with model: @script, url: script_path(@script), class: "flex flex-col gap-1" do |f| %>
            <div class="group relative pb-2" data-script-edit-target="field">
              <%= f.label :title, "title", class: "cf-h2 font-normal" %>
              <%= f.text_field :title,
                readonly: true,
                class: "cf-input cf-input-transparent border-0 rounded-none px-0 outline-none cursor-default",
                placeholder: "script title...",
                data: { script_edit_target: "input" } %>
              <span data-script-edit-target="line" class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-700 ease-in-out"></span>
            </div>

            <div class="group relative pb-2" data-script-edit-target="field">
              <%= f.label :style, "style", class: "cf-h2 font-normal" %>
              <%= f.text_field :style,
                readonly: true,
                class: "cf-input cf-input-transparent border-0 rounded-none px-0 outline-none cursor-default",
                placeholder: "e.g. educational, storytelling...",
                data: { script_edit_target: "input" } %>
              <span data-script-edit-target="line" class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-700 ease-in-out"></span>
            </div>

            <div class="group relative pb-2" data-script-edit-target="field">
              <%= f.label :length, "length", class: "cf-h2 font-normal" %>
              <%= f.text_field :length,
                readonly: true,
                class: "cf-input cf-input-transparent border-0 rounded-none px-0 outline-none cursor-default",
                placeholder: "e.g. short, medium, long...",
                data: { script_edit_target: "input" } %>
              <span data-script-edit-target="line" class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-700 ease-in-out"></span>
            </div>

            <div class="group relative pb-2" data-script-edit-target="field">
              <%= f.label :description, "description", class: "cf-h2 font-normal" %>
              <%= f.text_area :description,
                readonly: true,
                rows: 1,
                class: "cf-input cf-input-transparent border-0 rounded-none px-0 outline-none cursor-default h-auto py-3 resize-none overflow-hidden",
                placeholder: "what is this script about...",
                style: "field-sizing: content; min-height: 46px;",
                data: { script_edit_target: "input" } %>
              <span data-script-edit-target="line" class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-700 ease-in-out"></span>
            </div>

            <div class="group relative pb-2" data-script-edit-target="field">
              <%= f.label :system_prompt, "system prompt", class: "cf-h2 font-normal" %>
              <%= f.text_area :system_prompt,
                readonly: true,
                rows: 1,
                class: "cf-input cf-input-transparent border-0 rounded-none px-0 outline-none cursor-default h-auto py-3 resize-none overflow-hidden",
                placeholder: "ai instructions for generating this script...",
                style: "field-sizing: content; min-height: 46px;",
                data: { script_edit_target: "input" } %>
              <span data-script-edit-target="line" class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-700 ease-in-out"></span>
            </div>
          <% end %>
        </div>
        <div class="flex justify-end mt-6">
          <button type="button" data-script-edit-target="submit" data-action="script-edit#submit" class="opacity-0 pointer-events-none rounded-[10px] border-2 border-[var(--cf-ink)] bg-transparent text-[var(--cf-ink)] px-8 py-3.5 cf-action font-normal cursor-pointer transition-all duration-300 ease-in-out hover:bg-[var(--cf-accent)] hover:border-[var(--cf-accent)] hover:text-[var(--cf-cream)]">update</button>
        </div>
      </div>
    </div>
  </div>
</div>
