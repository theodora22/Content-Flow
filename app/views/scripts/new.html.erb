<% content_for :title, "New Script" %>

<div class="min-h-screen">
  <div class="px-7 pt-8 pb-14">
    <nav class="mb-8 cf-meta">
      <%= link_to "ideas", ideas_path, class: "hover:text-[var(--cf-ink)] transition-colors duration-150" %>
      <span class="mx-2">›</span>
      <%= link_to @idea.title, idea_path(@idea), class: "hover:text-[var(--cf-ink)] transition-colors duration-150" %>
      <span class="mx-2">›</span>
      <span>new script</span>
    </nav>

    <h1 class="cf-headline text-[clamp(48px,8vw,120px)] mb-16">NEW SCRIPT</h1>

    <div class="max-w-2xl">
      <%= render "form", script: @script, url: idea_scripts_path(@idea) %>
    </div>
  </div>
</div>
