<% content_for :title, "ContentFlow." %>
<% content_for :body_class, "h-screen overflow-x-hidden" %>

<div class="flex-1 flex flex-col relative overflow-visible">
  <main class="flex-1 px-7 flex flex-col justify-center pt-8 overflow-visible">
    <h1 class="cf-hero text-[clamp(64px,14vw,180px)] font-normal">
      START<br>CREATING<br>GREAT<br>CONTENT
    </h1>

    <div class="flex items-end mt-16 gap-80">
      <p class="cf-h2 font-normal">
        Turn a single idea into Reel scripts and LinkedIn<br>
        posts with a strong hook — all in one flow.
      </p>

      <div class="shrink-0 relative">
        <%= image_tag "arrow.svg", class: "absolute bottom-full left-1/2 -translate-x-1/2 rotate-90 mb-4", style: "width: 320px; max-width: none;", alt: "" %>
        <%= link_to "try me", new_user_registration_path, class: "block rounded-[10px] border-2 border-[var(--cf-ink)] bg-transparent text-[var(--cf-ink)] px-8 py-3.5 cf-action font-normal no-underline hover:bg-[var(--cf-ink)] hover:text-[var(--cf-cream)] active:translate-y-px transition-colors duration-150 ease-in-out" %>
      </div>
    </div>
  </main>
</div>

