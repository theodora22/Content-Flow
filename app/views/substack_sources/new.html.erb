<%# Implicit template lookup: SubstackSourcesController#new renders this file
    because Rails looks for app/views/<controller_name>/<action_name>.html.erb
    → app/views/substack_sources/new.html.erb. No explicit render call needed. %>
<% content_for :title, "Add Substack source" %>

<div class="min-h-screen">
  <div class="px-7 pt-2">
    <%= render "shared/back_link", path: substack_sources_path, label: "go back to sources" %>
    <div class="flex justify-between items-end gap-4 mb-16">
      <h1 class="cf-headline text-[clamp(72px,13vw,120px)] mt-2.5">
        ADD<br>SOURCE
      </h1>
    </div>

    <%= render "form", source: @source %>
  </div>
</div>
