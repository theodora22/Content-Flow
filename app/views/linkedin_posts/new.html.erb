<% content_for :title, "New LinkedIn Post" %>

<div class="min-h-screen">
  <div class="px-7 pt-8 pb-14">
    <nav class="mb-8 cf-meta">
      <%= link_to "ideas", ideas_path, class: "hover:text-[var(--cf-ink)] transition-colors duration-150" %>
      <span class="mx-2">›</span>
      <%= link_to @script.idea.title, idea_path(@script.idea), class: "hover:text-[var(--cf-ink)] transition-colors duration-150" %>
      <span class="mx-2">›</span>
      <%= link_to @script.title, script_path(@script), class: "hover:text-[var(--cf-ink)] transition-colors duration-150" %>
      <span class="mx-2">›</span>
      <span>new linkedin post</span>
    </nav>

    <h1 class="cf-headline text-[clamp(48px,8vw,120px)] mb-16">NEW LINKEDIN POST</h1>

    <div class="max-w-2xl">
      <%#
        singular resource — POST goes to /scripts/:script_id/linkedin_post (no :id).
        script_linkedin_post_path(@script) generates that URL.
      %>
      <%= render "form", linkedin_post: @linkedin_post, url: script_linkedin_post_path(@script) %>
    </div>
  </div>
</div>
