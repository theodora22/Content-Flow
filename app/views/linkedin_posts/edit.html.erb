<% content_for :title, "Edit LinkedIn Post" %>

<div class="min-h-screen">
  <div class="px-7 pt-8 pb-14">
    <%= render "shared/back_link", path: script_linkedin_post_path(@script), label: "go back to post" %>

    <h1 class="cf-headline text-[clamp(48px,8vw,120px)] mb-16">EDIT POST</h1>

    <div class="max-w-2xl">
      <%#
        PATCH goes to /scripts/:script_id/linkedin_post — same path as show/new,
        distinguished only by HTTP method. No :id because it's a singular resource.
      %>
      <%= render "form", linkedin_post: @linkedin_post, url: script_linkedin_post_path(@script) %>
    </div>
  </div>
</div>
