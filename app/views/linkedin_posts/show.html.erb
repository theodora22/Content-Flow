<% content_for :title, @linkedin_post.title %>

<div class="flex flex-col min-h-screen" data-controller="form-reveal">
  <div class="px-7 pt-2 pb-20 flex flex-col flex-1 relative">
    <%= link_to script_path(@script), class: "cf-meta inline-flex items-center gap-2 hover:text-[var(--cf-orange)] transition-colors duration-150", style: "position: relative; z-index: 20; cursor: pointer; margin-bottom: 10px;" do %>
      <%= image_tag "arrow.svg", style: "width: 20px; height: 20px; transform: rotate(180deg); pointer-events: none;", alt: "" %>
      <span style="pointer-events: none;">go back to script</span>
    <% end %>

    <div class="flex justify-between items-start mb-0 relative z-10">
      <h1 class="cf-headline text-[clamp(40px,7vw,64px)]" style="margin-top: 0;"><%= @linkedin_post.title.upcase %></h1>
      <div class="shrink-0 pt-2">
        <button type="button" data-action="form-reveal#reveal" class="edit-pen-btn flex flex-col items-center shrink-0">
          <div class="w-14 h-14">
            <svg class="pen-icon-svg w-full h-full" preserveAspectRatio="none" overflow="visible" style="display: block;" viewBox="0 0 808.169 808.169" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M404.085 261.319L546.851 404.085M47.1694 761V582.542L582.542 47.1694L761 225.627L225.627 761H47.1694Z" stroke="var(--stroke-0, black)" stroke-width="50" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="w-14 mt-1 h-0.5 overflow-hidden transition-all duration-500 ease-in-out">
            <div class="pen-line-inner w-14 h-0.5">
              <svg class="w-full h-full" preserveAspectRatio="none" overflow="visible" style="display: block;" viewBox="0 0 761 31.4463" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="15.7231" y1="15.7231" x2="745.277" y2="15.7231" stroke="var(--stroke-0, black)" stroke-width="31.4463" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
          <span class="edit-label cf-meta mt-1 w-14 text-center tracking-[0.3em]">edit</span>
        </button>
      </div>
    </div>

    <%# ---- Content Container ---- %>
    <div class="relative flex-1 flex flex-col -mt-[18px]">
      <div class="relative flex-1 flex flex-col w-full">
        <div class="flex flex-col flex-1 pb-32 pt-2">
          <%
            creator_name = current_user.creator&.name.presence || "Anonymous Creator"
            initials = "CF"
            if creator_name.present?
              parts = creator_name.strip.split(/\s+/)
              initials = parts.map { |p| p[0] }.join("").upcase[0..1] if parts.any?
            end
          %>

          <%= form_with model: @linkedin_post, url: script_linkedin_post_path(@script), id: "creator-form", class: "w-full flex flex-col items-center" do |f| %>
            <div class="bg-[var(--cf-white)] px-6 pt-4 pb-12 md:px-8 md:pt-4 md:pb-12 border border-black shadow-[8px_8px_0px_0px_#000] rounded-[24px] w-full relative overflow-hidden transition-all duration-300 hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[10px_10px_0px_0px_#000] mb-6 mx-auto">
              <!-- Platform Icon in Top Right -->
              <div class="absolute top-5 right-5 w-7 h-7 pointer-events-none">
                <%= image_tag "linkedin.svg", class: "w-full h-full object-contain opacity-70" %>
              </div>

              <!-- Mock Card Header -->
              <div class="flex items-center gap-3 border-b border-black pb-3 mb-4">
                <div class="w-11 h-11 rounded-full bg-[var(--cf-orange)] flex items-center justify-center text-[var(--cf-cream)] font-bold text-base border border-black shrink-0">
                  <%= initials %>
                </div>
                <div class="min-w-0">
                  <div class="flex items-center gap-1.5 leading-none">
                    <span class="text-sm font-bold text-[var(--cf-ink)]"><%= creator_name %></span>
                    <span class="text-xs text-[var(--cf-gray)]">• 1st</span>
                  </div>
                  <p class="text-xs text-[var(--cf-gray)] mt-0.5 leading-none">
                    <%= current_user.creator&.topic.presence || "Content Creator" %>
                  </p>
                  <p class="text-[11px] text-[var(--cf-gray)] mt-0.5 leading-none">
                    1h
                  </p>
                </div>
              </div>

              <!-- Mock Card Content (Editable In-place inputs) -->
              <div class="space-y-4">
                <div class="group relative pb-1">
                  <span class="text-[10px] uppercase tracking-wider block text-[var(--cf-gray)] mb-0.5">Hook</span>
                  <%= f.text_area :hook,
                    readonly: true,
                    class: "cf-input cf-input-transparent border-0 rounded-none pl-0 pr-4 outline-none cursor-default w-full h-auto py-0.5 resize-none font-bold text-base text-[var(--cf-ink)] focus:ring-0",
                    style: "field-sizing: content; min-height: 30px;",
                    data: { form_reveal_target: "input" } %>
                  <span data-form-reveal-target="line" class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-700 ease-in-out"></span>
                </div>

                <div class="group relative pb-1">
                  <span class="text-[10px] uppercase tracking-wider block text-[var(--cf-gray)] mb-0.5">Body</span>
                  <%= f.text_area :body,
                    readonly: true,
                    class: "cf-input cf-input-transparent border-0 rounded-none pl-0 pr-4 outline-none cursor-default w-full h-auto py-0.5 resize-none text-base text-[var(--cf-ink)] focus:ring-0",
                    style: "field-sizing: content; min-height: 80px;",
                    data: { form_reveal_target: "input" } %>
                  <span data-form-reveal-target="line" class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-700 ease-in-out"></span>
                </div>
              </div>

              <!-- Delete Post Link inside the box -->
              <div class="absolute bottom-3 right-6 md:right-8 z-10">
                <%= link_to "delete post", script_linkedin_post_path(@script),
                      data: { turbo_method: :delete, turbo_confirm: "Delete this LinkedIn post?" },
                      class: "cf-meta text-[var(--cf-orange)] hover:text-[var(--cf-orange-press)] transition-colors duration-150" %>
              </div>
            </div>

            <!-- Submit and Actions area (fades in under card) -->
            <div class="flex justify-end items-center w-full px-2 mx-auto">
              <button type="button" 
                      data-form-reveal-target="submit" 
                      data-action="form-reveal#submit" 
                      class="shrink-0 opacity-0 pointer-events-none rounded-[10px] border-2 border-[var(--cf-ink)] bg-transparent text-[var(--cf-ink)] px-8 py-3.5 cf-action font-normal cursor-pointer transition-all duration-300 ease-in-out hover:bg-[var(--cf-accent)] hover:border-[var(--cf-accent)] hover:text-[var(--cf-cream)]">
                update post
              </button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
