<% content_for :title, "Create Profile" %>

<div class="min-h-screen bg-[var(--cf-bg)]">
  <div class="px-7 pt-8">
    <h1 class="cf-headline text-[clamp(48px,8vw,90px)]">
      CREATE YOUR<br>PROFILE
    </h1>

    <div class="cf-rule mt-6 mb-10"></div>

    <%= form_with model: @creator, url: creator_path do |f| %>
      <% if @creator.errors.any? %>
        <div class="mb-8">
          <ul class="cf-meta text-[var(--cf-orange)]">
            <% @creator.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="max-w-xl space-y-6">
        <div>
          <%= f.label :name, "name", class: "cf-label font-normal block mb-2" %>
          <%= f.text_field :name, class: "w-full bg-[var(--cf-field-bg)] border border-[var(--cf-gray-line)] rounded-[var(--cf-radius)] px-4 h-12 cf-body" %>
        </div>

        <div>
          <%= f.label :topic, "what do you create content about?", class: "cf-label font-normal block mb-2" %>
          <%= f.text_field :topic, class: "w-full bg-[var(--cf-field-bg)] border border-[var(--cf-gray-line)] rounded-[var(--cf-radius)] px-4 h-12 cf-body" %>
        </div>

        <div>
          <%= f.label :goal, "what is your content goal?", class: "cf-label font-normal block mb-2" %>
          <%= f.text_field :goal, class: "w-full bg-[var(--cf-field-bg)] border border-[var(--cf-gray-line)] rounded-[var(--cf-radius)] px-4 h-12 cf-body" %>
        </div>

        <div>
          <%= f.label :audience, "who is your target audience?", class: "cf-label font-normal block mb-2" %>
          <%= f.text_field :audience, class: "w-full bg-[var(--cf-field-bg)] border border-[var(--cf-gray-line)] rounded-[var(--cf-radius)] px-4 h-12 cf-body" %>
        </div>

        <div class="pt-4">
          <%= f.submit "create profile", class: "bg-[var(--cf-orange)] text-[var(--cf-cream)] rounded-[var(--cf-radius)] px-8 py-3 cf-label font-normal cursor-pointer hover:bg-[var(--cf-orange-press)] active:translate-y-px transition-colors duration-150 ease-in-out" %>
        </div>
      </div>
    <% end %>
  </div>
  </div>
