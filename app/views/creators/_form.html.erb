<%= render "shared/errors", record: creator %>

<%= form_with model: creator, url: creator_path, id: "creator-form", class: "flex flex-col gap-4" do |f| %>
  <div class="group relative pb-2">
    <%= f.label :name, "name", class: "cf-h2 font-normal" %>
    <%= f.text_area :name,
      rows: 1,
      readonly: !editable,
      class: "cf-input border-0 rounded-none bg-transparent px-0 outline-none resize-none h-auto py-1 #{editable ? 'cursor-text' : 'cursor-default'} focus:ring-0",
      placeholder: "your name...",
      style: "field-sizing: content; min-height: 34px;",
      data: {
        form_reveal_target: "input",
        action: "input->form-reveal#updatePreview"
      } %>
    <span data-form-reveal-target="line" class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-700 ease-in-out"></span>
  </div>

  <div class="group relative pb-2">
    <%= f.label :topic, "what do you create content about?", class: "cf-h2 font-normal" %>
    <%= f.text_area :topic,
      rows: 1,
      readonly: !editable,
      class: "cf-input border-0 rounded-none bg-transparent px-0 outline-none resize-none h-auto py-1 #{editable ? 'cursor-text' : 'cursor-default'} focus:ring-0",
      placeholder: "e.g. fitness, cooking, tech...",
      style: "field-sizing: content; min-height: 34px;",
      data: {
        form_reveal_target: "input",
        action: "input->form-reveal#updatePreview"
      } %>
    <span data-form-reveal-target="line" class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-700 ease-in-out"></span>
  </div>

  <div class="group relative pb-2">
    <%= f.label :goal, "what is your content goal?", class: "cf-h2 font-normal" %>
    <%= f.text_area :goal,
      rows: 1,
      readonly: !editable,
      class: "cf-input border-0 rounded-none bg-transparent px-0 outline-none resize-none h-auto py-1 #{editable ? 'cursor-text' : 'cursor-default'} focus:ring-0",
      placeholder: "e.g. grow my audience, land clients...",
      style: "field-sizing: content; min-height: 34px;",
      data: {
        form_reveal_target: "input",
        action: "input->form-reveal#updatePreview"
      } %>
    <span data-form-reveal-target="line" class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-700 ease-in-out"></span>
  </div>

  <div class="group relative pb-2">
    <%= f.label :audience, "who is your target audience?", class: "cf-h2 font-normal" %>
    <%= f.text_area :audience,
      rows: 1,
      readonly: !editable,
      class: "cf-input border-0 rounded-none bg-transparent px-0 outline-none resize-none h-auto py-1 #{editable ? 'cursor-text' : 'cursor-default'} focus:ring-0",
      placeholder: "e.g. beginners, small business owners...",
      style: "field-sizing: content; min-height: 34px;",
      data: {
        form_reveal_target: "input",
        action: "input->form-reveal#updatePreview"
      } %>
    <span data-form-reveal-target="line" class="absolute bottom-0 left-0 h-px w-0 bg-black transition-all duration-700 ease-in-out"></span>
  </div>

  <%# Hidden upload input — triggered by clicking the avatar circle in the
      identity card, which is a <label for="creator_avatar"> pointing here.
      It must live inside the form so the file is submitted with it. %>
  <%= f.file_field :avatar,
    accept: "image/*",
    disabled: !editable,
    class: "hidden",
    data: {
      form_reveal_target: "input",
      action: "change->form-reveal#updateAvatar"
    } %>

  <% if editable %>
    <%= f.submit creator.persisted? ? "update" : "create profile",
      class: "cf-btn-primary self-start mt-4 cursor-pointer" %>
  <% end %>
<% end %>
