<div data-controller="form-reveal">
  <div class="px-7 pt-8 pb-16">
    <%# Page Header %>
    <div class="flex justify-between items-end gap-4 mb-16">
      <h1 class="cf-headline text-[clamp(72px,13vw,120px)]">
        <% if @creator.persisted? %>
          YOUR<br>PROFILE
        <% else %>
          CREATE<br>PROFILE
        <% end %>
      </h1>

      <% if @creator.persisted? %>
        <button type="button" data-action="form-reveal#reveal" class="edit-pen-btn flex flex-col items-center shrink-0">
          <div class="w-14 h-14">
            <svg class="pen-icon-svg w-full h-full" preserveAspectRatio="none" overflow="visible" style="display: block;" viewBox="0 0 808.169 808.169" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M404.085 261.319L546.851 404.085M47.1694 761V582.542L582.542 47.1694L761 225.627L225.627 761H47.1694Z" stroke="var(--stroke-0, black)" stroke-width="50" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="w-14 mt-1 h-0.5 overflow-hidden transition-all duration-500 ease-in-out">
            <div class="pen-line-inner w-14 h-0.5">
              <svg class="w-full h-full" preserveAspectRatio="none" overflow="visible" style="display: block;" viewBox="0 0 761 31.4463" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="15.7231" y1="15.7231" x2="745.277" y2="15.7231" stroke="var(--stroke-0, black)" stroke-width="31.4463" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
          <span class="edit-label cf-meta mt-1 w-14 text-center tracking-[0.3em]">edit</span>
        </button>
      <% end %>
    </div>

    <%# Main Grid Content %>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start mt-8">
      <%# Left Column: Form %>
      <div class="md:col-span-7 max-w-xl">
        <%= render "form", creator: @creator, editable: !@creator.persisted? %>
        
        <% if @creator.persisted? %>
          <div class="mt-8">
            <button type="button" 
                    data-form-reveal-target="submit" 
                    data-action="form-reveal#submit" 
                    class="shrink-0 opacity-0 pointer-events-none rounded-[10px] border-2 border-[var(--cf-ink)] bg-transparent text-[var(--cf-ink)] px-8 py-3.5 cf-action font-normal cursor-pointer transition-all duration-300 ease-in-out hover:bg-[var(--cf-accent)] hover:border-[var(--cf-accent)] hover:text-[var(--cf-cream)]">
              update profile
            </button>
          </div>
        <% end %>
      </div>

      <%# Right Column: Visual Identity Card %>
      <div class="md:col-span-5 md:mt-12 sticky top-8">
        <div class="bg-[var(--cf-white)] p-8 border-2 border-black shadow-[16px_16px_0px_0px_#000] rounded-[32px] relative overflow-hidden transition-all duration-300 hover:translate-x-[-4px] hover:translate-y-[-4px] hover:shadow-[20px_20px_0px_0px_#000]">
          <!-- Card Header -->
          <div class="flex justify-between items-start border-b border-[var(--cf-gray-line)] pb-4 mb-6">
            <div>
              <span class="cf-meta text-[var(--cf-orange)] uppercase tracking-widest text-xs font-bold">Identity Pass</span>
              <h3 class="cf-h2 font-black tracking-tight leading-none mt-1">CREATOR IDENTITY</h3>
            </div>
            <%
              initials = "CF"
              if @creator.name.present?
                parts = @creator.name.strip.split(/\s+/)
                initials = parts.map { |p| p[0] }.join("").upcase[0..1] if parts.any?
              end
            %>
            <div id="preview-initials" class="w-10 h-10 rounded-full bg-[var(--cf-orange)] flex items-center justify-center text-[var(--cf-cream)] font-bold text-lg">
              <%= initials %>
            </div>
          </div>

          <!-- Card Body -->
          <div class="space-y-6">
            <div>
              <span class="cf-meta uppercase text-[10px] tracking-wider block text-[var(--cf-gray)]">Creator Name</span>
              <p class="cf-h2 font-bold tracking-tight text-[var(--cf-ink)] border-b border-dashed border-[var(--cf-gray-line)] pb-1 truncate" id="preview-name">
                <%= @creator.name.presence || "Anonymous Creator" %>
              </p>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <span class="cf-meta uppercase text-[10px] tracking-wider block text-[var(--cf-gray)]">Domain / Topic</span>
                <p class="cf-body font-bold text-[var(--cf-orange)]" id="preview-topic">
                  <%= @creator.topic.presence || "Not specified yet" %>
                </p>
              </div>
              <div>
                <span class="cf-meta uppercase text-[10px] tracking-wider block text-[var(--cf-gray)]">Core Goal</span>
                <p class="cf-body font-bold" id="preview-goal">
                  <%= @creator.goal.presence || "Not specified yet" %>
                </p>
              </div>
            </div>

            <div>
              <span class="cf-meta uppercase text-[10px] tracking-wider block text-[var(--cf-gray)]">Target Audience</span>
              <p class="cf-body text-[var(--cf-gray)] italic" id="preview-audience">
                <%= @creator.audience.present? ? "\"#{@creator.audience}\"" : "\"Not specified yet\"" %>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
