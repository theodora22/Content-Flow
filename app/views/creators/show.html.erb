<div class="max-w-lg mx-auto mt-10 px-4">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Creator Profile</h1>
    <%= link_to "Edit profile", edit_creator_path, class: "text-sm border rounded px-4 py-2 hover:bg-gray-50" %>
    <%= link_to "Home", root_path, class: "text-sm border rounded px-4 py-2 hover:bg-gray-50" %>
    <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete } %>
  </div>

  <dl class="divide-y divide-gray-100">
    <div class="py-4">
      <dt class="text-sm font-medium text-gray-500 mb-1">Name</dt>
      <dd class="text-base"><%= @creator.name %></dd>
    </div>

    <div class="py-4">
      <dt class="text-sm font-medium text-gray-500 mb-1">What do you create content about?</dt>
      <dd class="text-base"><%= @creator.topic %></dd>
    </div>

    <div class="py-4">
      <dt class="text-sm font-medium text-gray-500 mb-1">Content goal</dt>
      <dd class="text-base"><%= @creator.goal %></dd>
    </div>

    <div class="py-4">
      <dt class="text-sm font-medium text-gray-500 mb-1">Target audience</dt>
      <dd class="text-base"><%= @creator.audience %></dd>
    </div>
  </dl>
</div>
